<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="DotNetAppPublisher.Views.ScreenshotDialog"
        Title="Screenshot"
        Width="400"
        Height="280"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False">
    
    <Window.Styles>
        <Style Selector="Border.dialog-card">
            <Setter Property="Background" Value="{DynamicResource ThemeBackgroundColor}"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="32"/>
            <Setter Property="BoxShadow" Value="0 20 60 0 #110E1740"/>
        </Style>
        
        <Style Selector="TextBlock.countdown-text">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
        </Style>
        
        <Style Selector="TextBlock.completion-text">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#22C55E"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>
        
        <Style Selector="ProgressBar.screenshot-progress">
            <Setter Property="Height" Value="8"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="Margin" Value="0,16,0,0"/>
        </Style>
        
        <Style Selector="PathIcon.camera-icon">
            <Setter Property="Width" Value="64"/>
            <Setter Property="Height" Value="64"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundColor}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
    </Window.Styles>

    <Grid Background="#80000000">
        <Border HorizontalAlignment="Center" 
                VerticalAlignment="Center"
                Classes="dialog-card">
            <StackPanel Spacing="20" HorizontalAlignment="Center">
                <!-- Camera Icon -->
                <PathIcon Classes="camera-icon">
                    <PathIcon.Data>
                        M20 6h-3.17L15 4H9L7.17 6H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm-8 14c-3.31 0-6-2.69-6-6s2.69-6 6-6 6 2.69 6 6-2.69 6-6 6zm0-10c-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4-1.79-4-4-4zm0 2c1.1 0 2 .9 2 2s-.9 2-2 2-2-.9-2-2 .9-2 2-2z
                    </PathIcon.Data>
                </PathIcon>
                
                <!-- Countdown Text -->
                <TextBlock x:Name="CountdownTextBlock" 
                           Classes="countdown-text"
                           Text="Preparing screenshot..."/>
                
                <!-- Progress Bar -->
                <ProgressBar x:Name="Progress" 
                             Classes="screenshot-progress"
                             Value="100"
                             IsIndeterminate="False"/>
                
                <!-- Completion Message (hidden by default) -->
                <TextBlock x:Name="CompletionTextBlock"
                           Classes="completion-text"
                           IsVisible="False"
                           Text="✓ Screenshot captured!"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
